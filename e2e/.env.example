# Variables d'environnement pour les tests E2E Playwright
# Copier ce fichier en .env.local et remplir les valeurs

# URL de l'app (production ou local)
E2E_BASE_URL=https://app.crazy-chrono.com
E2E_BACKEND_URL=https://crazy-chrono-backend.onrender.com

# Compte admin/prof pour les tests (email + mot de passe)
E2E_ADMIN_EMAIL=verinmarius971@gmail.com
E2E_ADMIN_PASSWORD=votre_mot_de_passe_ici

# Code élève pour les tests (optionnel)
E2E_STUDENT_CODE=CODE-ELEVE-XXXX
